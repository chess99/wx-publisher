{
  "name": "fixture-theme-dangerous",
  "description": "External theme fixture with dangerous CSS",
  "styles": {
    "wrapper": "font-family:Arial,sans-serif;max-width:677px;margin:0 auto;",
    "h1": "font-size:26px;font-weight:700;",
    "h2": "font-size:20px;font-weight:700;",
    "h3": "font-size:17px;font-weight:700;",
    "h4": "font-size:16px;font-weight:700;",
    "p": "font-size:16px;line-height:1.8;",
    "strong": "font-weight:700;",
    "em": "font-style:italic;",
    "code": "font-family:Consolas,monospace;font-size:13px;",
    "pre": "background:#111;padding:16px;overflow-x:auto;",
    "preCode": "font-family:Consolas,monospace;font-size:13px;",
    "blockquote": "border-left:4px solid #ddd;padding-left:12px;",
    "ul": "padding-left:20px;",
    "ol": "padding-left:20px;",
    "li": "margin:0.2em 0;",
    "hr": "border:none;border-top:1px solid #ddd;",
    "img": "max-width:100%;background:url(javascript:alert(1));",
    "a": "color:#06c;",
    "table": "width:100%;border-collapse:collapse;",
    "th": "font-weight:700;",
    "td": "padding:8px;"
  }
}
